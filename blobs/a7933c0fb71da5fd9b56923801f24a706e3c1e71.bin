lude &lt;iostream&gt;
#include &lt;vector&gt;
#include &lt;string&gt;

//=E7=B0=A1=E6=98=93=E3=81=AA=E3=83=87=E3=82=A3=E3=83=AC=E3=82=AF=E3=83=88=
=E3=83=AA=E6=A7=8B=E9=80=A0=E8=A1=A8=E7=8F=BE=E3=82=AF=E3=83=A9=E3=82=B9
class directory {

  //=E4=B8=8D=E5=AE=8C=E5=85=A8=E5=9E=8B=EF=BC=88=E3=82=AF=E3=83=A9=E3=82=
=B9=E5=AE=9A=E7=BE=A9=E5=86=85=E3=81=A7=E3=81=AF=E3=81=9D=E3=81=AE=E3=82=AF=
=E3=83=A9=E3=82=B9=E8=87=AA=E8=BA=AB=E3=81=AF=E4=B8=8D=E5=AE=8C=E5=85=A8=EF=
=BC=89=E3=82=92=E8=A6=81=E7=B4=A0=E5=9E=8B=E3=81=AB=E6=8C=87=E5=AE=9A
  std::vector&lt;directory&gt; m_subdir{};
  std::string m_name{};

public:

  directory(const char* name) : m_name{name}
  {}

  //=E3=82=B5=E3=83=96=E3=83=87=E3=82=A3=E3=83=AC=E3=82=AF=E3=83=88=E3=83=
=AA=E8=BF=BD=E5=8A=A0
  template&lt;typename Dir&gt;
  void add(Dir&amp;&amp; dir) {
    m_subdir.emplace_back(std::forward&lt;Dir&gt;(dir));
  }

  //=E3=83=87=E3=82=A3=E3=83=AC=E3=82=AF=E3=83=88=E3=83=AA=E5=90=8D=E5=8F=
=96=E5=BE=97
  auto get() const -&gt; const std::string&amp; {
    return m_name;
  }

  auto begin() const {
    return m_subdir.begin();
  }

  auto end() const {
    return m_subdir.end();
  }
};

//=E3=83=AB=E3=83=BC=E3=83=88=E3=82=88=E3=82=8A=E4=B8=8B=E3=81=AE=E3=83=87=
=E3=82=A3=E3=83=AC=E3=82=AF=E3=83=88=E3=83=AA=E3=81=AB=E3=81=A4=E3=81=84=E3=
=81=A6=E6=95=B4=E5=BD=A2=E3=81=97=E3=81=A6=E5=87=BA=E5=8A=9B
void recursive_out(const directory&amp; dir, unsigned int depth) {

  if (1 &lt; depth) std::cout &lt;&lt; "| ";
  for (auto i =3D depth; 2 &lt; i; --i) {
    std::cout &lt;&lt; " ";
  }
  if (2 &lt; depth) std::cout &lt;&lt; " ";

  std::cout &lt;&lt; "|-" &lt;&lt; dir.get() &lt;&lt; std::endl;

  for (auto&amp; subdir : dir) {
    recursive_out(subdir, depth + 1);
  }
}

//=E3=83=87=E3=82=A3=E3=83=AC=E3=82=AF=E3=83=88=E3=83=AA=E6=A7=8B=E9=80=A0=
=E3=82=92=E5=87=BA=E5=8A=9B=E3=81=99=E3=82=8B
void out_directorytree(const directory&amp; dir) {
  std::cout &lt;&lt; dir.get() &lt;&lt; std::endl;

  for (auto&amp; subdir : dir) {
    recursive_out(subdir, 1);
  }
}

int main() {
  directory dir{"root"};
  dir.add("sub1");

  directory sub2{"sub2"};
  sub2.add("sub2.1");

  directory sub22{"sub2.2"};
  sub22.add("sub2.2.1");

  sub2.add(std::move(sub22));

  dir.add(std::move(sub2));
  dir.add("sub3");

  out_directorytree(dir);
}
